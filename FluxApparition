// ============================================================
// FAST MATH / HELPERS
// ============================================================
static inline float fast_sin7(float x)
{
    float x2 = x * x;
    return x * (1.0f - x2 * (0.16666667f - x2 * (0.00833333f - x2 * 0.000198413f)));
}

static inline float fast_sine_phase(float p)
{
    return fast_sin7((p - 0.5f) * TWO_PI_F);
}

static inline float fast_sin_hp(float x)
{
    float x2 = x * x;
    return x * (1.0f - x2 * (0.16666667f - x2 * 0.00833333f));
}

static inline float fast_cos_hp(float x)
{
    float x2 = x * x;
    return 1.0f - x2 * (0.5f - x2 * 0.04166667f);
}

static inline float fast_tanh(float x)
{
    return x / (1.0f + fabsf(x));
}

static inline float tape_warm(float x)
{
    return x - 0.15f * x * x * x;
}

static inline float soft_limit(float x)
{
    float ax = fabsf(x);
    if(ax < 0.7f)
        return x;
    float k = (ax - 0.7f) * 1.5f;
    return x / (1.0f + k * ax);
}

static inline float bbd_saturate(float x)
{
    return x / (1.0f + fabsf(x));
}

static inline float tri01(float p)
{
    float x = p - floorf(p);
    return (x < 0.5f) ? (x * 2.0f) : (2.0f - x * 2.0f);
}

static inline float clampf(float x, float lo, float hi)
{
    return std::max(lo, std::min(x, hi));
}

static inline float clamp01(float x)
{
    return clampf(x, 0.0f, 1.0f);
}

static inline float smoothshape01(float x)
{
    x = clamp01(x);
    return x * x * (3.0f - 2.0f * x);
}

// ============================================================
// BASIC FILTERS
// ============================================================
struct Lp1
{
    float y, c;
    void Init(float freq, float sr)
    {
        y = 0.0f;
        c = 1.0f - expf(-TWO_PI_F * freq / sr);
    }
    void SetFreq(float freq, float sr)
    {
        c = 1.0f - expf(-TWO_PI_F * freq / sr);
    }
    float Process(float x)
    {
        y += c * (x - y);
        return y;
    }
};

struct Hp1
{
    float y, c;
    void Init(float freq, float sr)
    {
        y = 0.0f;
        c = 1.0f - expf(-TWO_PI_F * freq / sr);
    }
    void SetFreq(float freq, float sr)
    {
        c = 1.0f - expf(-TWO_PI_F * freq / sr);
    }
    float Process(float x)
    {
        y += c * (x - y);
        return x - y;
    }
};

struct BbdSvf
{
    float lo, bp, f, damp;
    void Init(float freq, float q, float sr)
    {
        lo = bp = 0.0f;
        SetFreq(freq, q, sr);
    }
    void SetFreq(float freq, float q, float sr)
    {
        freq = std::min(freq, sr * 0.45f);
        f    = 2.0f * fast_sin7(PI_F_LOCAL * freq / sr);
        damp = 1.0f / q;
    }
    float Process(float x)
    {
        float hp = x - lo - damp * bp;
        bp += f * hp;
        lo += f * bp;
        return bp * 0.5f + lo * 0.5f;
    }
};

struct SimpleDcBlock
{
    float x1, y1, r;
    void Init(float coeff = 0.995f)
    {
        x1 = 0.0f;
        y1 = 0.0f;
        r  = coeff;
    }
    float Process(float x)
    {
        float y = x - x1 + r * y1;
        x1 = x;
        y1 = y;
        return y;
    }
};

struct Ap
{
    float* buf;
    size_t len, wp;
    float  g;
    void Init(float* mem, size_t n, float coeff)
    {
        buf = mem;
        len = n;
        wp  = 0;
        g   = coeff;
        memset(buf, 0, n * sizeof(float));
    }
    float Process(float x)
    {
        float rd = buf[wp];
        float w  = x + rd * g;
        buf[wp]  = w;
        wp       = (wp + 1) % len;
        return rd - w * g;
    }
};

struct DelBuf
{
    float* buf;
    size_t len, wp;
    void Init(float* mem, size_t n)
    {
        buf = mem;
        len = n;
        wp  = 0;
        memset(buf, 0, n * sizeof(float));
    }
    void Write(float s)
    {
        buf[wp] = s;
        wp      = (wp + 1) % len;
    }
    float Read(float samps) const
    {
        samps = clampf(samps, 1.0f, (float)(len - 2));
        float r = (float)wp - samps;
        if(r < 0.0f)
            r += (float)len;

        int   i0 = (int)r;
        float fr = r - (float)i0;
        int   i1 = i0 + 1;
        if(i1 >= (int)len)
            i1 -= (int)len;
        if(i0 >= (int)len)
            i0 -= (int)len;

        return buf[i0] * (1.0f - fr) + buf[i1] * fr;
    }
};

// ============================================================
// VELVET NOISE
// ============================================================
struct VelvetNoise
{
    uint32_t lfsr;
    int      counter;

    void Init()
    {
        lfsr    = 0xDEADBEEF;
        counter = 0;
    }

    float Process()
    {
        uint32_t bit = ((lfsr >> 31) ^ (lfsr >> 21) ^ (lfsr >> 1) ^ lfsr) & 1u;
        lfsr         = (lfsr << 1) | bit;

        counter++;
        int spacing = 19 + (int)((lfsr >> 16) & 0x7) - 4;
        if(counter >= spacing)
        {
            counter = 0;
            return (lfsr & 2u) ? 0.0001f : -0.0001f;
        }
        return 0.0f;
    }
};

// ============================================================
// RANDOM WALK
// ============================================================
struct RandWalk
{
    uint32_t lfsr;
    float filtered;
    float position;
    float smoothC;

    void Init(uint32_t seed, float speed, float sr)
    {
        lfsr     = seed;
        filtered = 0.0f;
        position = 0.0f;
        smoothC  = 1.0f - expf(-TWO_PI_F * speed / sr);
    }

    float Process(float maxDepth)
    {
        uint32_t bit = ((lfsr >> 31) ^ (lfsr >> 21) ^ (lfsr >> 1) ^ lfsr) & 1u;
        lfsr         = (lfsr << 1) | bit;

        float noise = (float)(int32_t)(lfsr) * (1.0f / 2147483648.0f);
        filtered += smoothC * (noise - filtered);
        position += filtered * 0.02f;

        if(position > maxDepth)
            position = maxDepth - (position - maxDepth);
        if(position < -maxDepth)
            position = -maxDepth - (position + maxDepth);

        return position;
    }
};

