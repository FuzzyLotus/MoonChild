// ============================================================
// CHORUS ENGINE
// ============================================================
static inline void processChorus(float input, float rateHz, float shapeDepth,
                                 float &outL, float &outR)
{
    float bond  = sBond;
    float orbit = sOrbit;
    float halo  = sHalo;

    chPhaseA += rateHz / SR_F;
    chPhaseB += rateHz * 0.83f / SR_F;
    chPhaseC += rateHz * 0.61f / SR_F;

    if(chPhaseA >= 1.0f) chPhaseA -= 1.0f;
    if(chPhaseB >= 1.0f) chPhaseB -= 1.0f;
    if(chPhaseC >= 1.0f) chPhaseC -= 1.0f;

    float lfoA = tri01(chPhaseA);
    float lfoB = tri01(chPhaseB);
    float lfoC = tri01(chPhaseC);

    float baseMs  = 7.9f + bond * 0.8f + orbit * 0.9f;
    float depthMs = shapeDepth * (0.56f + orbit * 0.18f + halo * 0.04f);
    depthMs       = std::min(depthMs, 2.45f);

    float dA_ms = baseMs + lfoA * depthMs;
    float dB_ms = (baseMs + 1.9f) + lfoB * (depthMs * 0.90f);
    float dC_ms = (baseMs + 4.6f) + lfoC * (depthMs * 0.92f);

    float dA = dA_ms * SR_OVER_1000;
    float dB = dB_ms * SR_OVER_1000;
    float dC = dC_ms * SR_OVER_1000;

    dA = clampf(dA, 2.0f, (float)(CHORUS_BUF_SIZE - 3));
    dB = clampf(dB, 2.0f, (float)(CHORUS_BUF_SIZE - 3));
    dC = clampf(dC, 2.0f, (float)(CHORUS_BUF_SIZE - 3));

    float writeSig = chWriteHpf.Process(chWriteLpf.Process(input));

    bool frozen = sChFz > 0.5f;
    if(frozen)
    {
        chDel[0].Write(chDel[0].Read(dA) * 0.9995f);
        chDel[1].Write(chDel[1].Read(dB) * 0.9995f);
        chDel[2].Write(chDel[2].Read(dC) * 0.9995f);
    }
    else
    {
        chDel[0].Write(writeSig);
        chDel[1].Write(writeSig);
        chDel[2].Write(writeSig);
    }

    float vA = chDel[0].Read(dA);
    float vB = chDel[1].Read(dB);
    float vC = chDel[2].Read(dC);

    vA = chVoiceDc[0].Process(chVoiceLpf[0].Process(vA));
    vB = chVoiceDc[1].Process(chVoiceLpf[1].Process(vB));
    vC = chVoiceDc[2].Process(chVoiceLpf[2].Process(vC));

    float width = 0.24f + orbit * 0.12f + halo * 0.05f + (1.0f - bond) * 0.03f;
    float glue  = halo * 0.78f;
    float cSide = halo * 0.22f;

    float mid  = (vA + vB) * 0.5f;
    float side = (vA - vB) * width;

    float left  = mid + side + vC * (glue + cSide);
    float right = mid - side + vC * (glue - cSide);

    left  = tape_warm(left * 0.93f);
    right = tape_warm(right * 0.93f);

    outL = bbd_saturate(left);
    outR = bbd_saturate(right);
}

// ============================================================
// REVERB ENGINE
// ============================================================
static inline void processReverb(float input, float &outL, float &outR)
{
    float bond      = sBond;
    float orbit     = sOrbit;
    float character = sCharacter;
    float series    = sBondMode;

    float inGain = 1.0f - 0.85f * sRvFz;

    float fbCoeff = sBloom
                  + bond * 0.060f
                  + orbit * 0.040f
                  + series * 0.022f;
    fbCoeff = std::min(fbCoeff, 0.948f);

    float diffused = input;
    for(int s = 0; s < 6; s++)
        diffused = inDiff[s].Process(diffused);

    float inRect = fabsf(input);
    if(inRect > vnEnv)
        vnEnv += 0.05f * (inRect - vnEnv);
    else
        vnEnv *= 0.9999f;

    float vnGate  = std::min(1.0f, vnEnv * 15.0f) * (1.0f - sRvFz);
    float rvInput = diffused + velvet.Process() * vnGate;

    // Character is deliberately kept OUT of the tank voicing to avoid the SW4 pop.
    rvInput *= (0.96f + bond * 0.07f + orbit * 0.06f + series * 0.03f);

    float baseTaps[FDN_N];
    for(int t = 0; t < FDN_N; t++)
    {
        // Fixed stable tank voicing; SW4 handled outside the tank
        baseTaps[t] = (float)TAP_BRIGHT[t];
    }

    float modDepthTap = TAP_MOD_DEPTH * (1.0f - sRvFz * 0.8f);
    float walk[FDN_N];
    for(int t = 0; t < FDN_N; t++)
        walk[t] = tapWalk[t].Process(modDepthTap);

    float xModScale = XFEED_MOD_DEPTH / TAP_MOD_DEPTH;
    walk[2] += walk[6] * xModScale;
    walk[5] += walk[1] * xModScale;
    walk[4] += walk[0] * xModScale;
    walk[7] += walk[3] * xModScale;

    float rd[FDN_N];
    for(int t = 0; t < FDN_N; t++)
        rd[t] = rvDel[t].Read(baseTaps[t] + walk[t]);

    float rdSum = 0.0f;
    for(int t = 0; t < FDN_N; t++)
        rdSum += rd[t];

    revEnergy = revEnergyLpf.Process(fabsf(rdSum) / (float)FDN_N);

    static constexpr float INV_SQRT_N = 0.354f;
    float inputScaled = rvInput * inGain * INV_SQRT_N;

    for(int t = 0; t < FDN_N; t++)
    {
        float mixed    = rd[t] - HOUSE_COEFF * rdSum;
        float filtered = rvDamp[t].Process(mixed);
        float fbInput  = filtered + (mixed - filtered) * (sRvFz * 0.33f + orbit * 0.05f);
        float fb       = fbInput * fbCoeff;
        float fbClip   = fast_tanh(fb);
        fb             = fbClip + (fb - fbClip) * sRvFz;
        rvDel[t].Write(inputScaled + fb);
    }

    float lateL = 0.0f;
    float lateR = 0.0f;
    float plateLate = 0.020f + orbit * 0.003f + series * 0.002f;
    float hallLate  = 0.044f + orbit * 0.009f + series * 0.006f;
    float lateLevel = plateLate + (hallLate - plateLate) * character;

    for(int t = 0; t < FDN_N; t++)
    {
        float latePos = baseTaps[t] * LATE_TAP_FRAC;
        float lt      = rvDel[t].Read(latePos) * lateLevel;
        float sign    = (t & 1) ? -1.0f : 1.0f;
        lateL += lt * sign;
        lateR -= lt * sign;
    }

    float plateMain = 0.66f + orbit * 0.01f;
    float hallMain  = 0.50f + orbit * 0.03f;
    float mainGain  = plateMain + (hallMain - plateMain) * character;

    float mainL = (rd[0] + rd[3] + rd[4] + rd[7]) * mainGain;
    float mainR = (rd[1] + rd[2] + rd[5] + rd[6]) * mainGain;

    float rawL = mainL + lateL;
    float rawR = mainR + lateR;

    outL = rvHpfL.Process(rawL);
    outR = rvHpfR.Process(rawR);
}

// ============================================================
// AUDIO CALLBACK
// ============================================================
static void AudioCallback(AudioHandle::InputBuffer in,
                          AudioHandle::OutputBuffer out,
                          size_t size)
{
    for(size_t i = 0; i < size; i++)
    {
        // Smooth controls
        fonepole(sMotion,   tMotion,   0.005f);
        fonepole(sPresence, tPresence, 0.005f);
        fonepole(sBloom,    tBloom,    0.005f);
        fonepole(sShape,    tShape,    0.002f);
        fonepole(sBond,     tBond,     0.002f);
        fonepole(sColor,    tColor,    0.005f);

        fonepole(sHalo,      tHalo,      0.002f);
        fonepole(sBondMode,  tBondMode,  0.002f);
        fonepole(sOrbit,     tOrbit,     0.002f);
        fonepole(sCharacter, tCharacter, 0.0008f);

        fonepole(sChOn,     tChOn,     0.002f);
        fonepole(sRvOn,     tRvOn,     0.002f);

        float rvFzC = (tRvFz > sRvFz) ? 0.004f : 0.00002f;
        float chFzC = (tChFz > sChFz) ? 0.004f : 0.00002f;
        fonepole(sRvFz, tRvFz, rvFzC);
        fonepole(sChFz, tChFz, chFzC);

        // Input conditioning
        float raw = in[0][i];
        float dry = tape_warm(inputHpf.Process(inputLpf.Process(raw)));

        float anyOn = std::min(1.0f, sChOn + sRvOn);

        // Slow drift
        driftPhase += DRIFT_FREQ / SR_F;
        if(driftPhase >= 1.0f)
            driftPhase -= 1.0f;
        driftVal = fast_sine_phase(driftPhase);

        float dynDrift = std::min(DRIFT_AMOUNT * (1.0f + revEnergy * 1.2f), 0.6f);
        float shapeDepth = sShape * (1.0f + driftVal * dynDrift);

        float bondMacro = smoothshape01(sBond);
        float orbitRate = sMotion * (1.0f - sOrbit * 0.15f) + sOrbit * 0.03f;

        // Chorus
        float chIn = dry * sChOn;
        chIn = soft_limit(chIn);

        float chL = 0.0f, chR = 0.0f;
        processChorus(chIn, orbitRate, shapeDepth, chL, chR);
        float chMono = (chL + chR) * 0.5f;

        // Bond system
        float bondModeAmt   = sBondMode;
        float bondModeBoost = 1.0f + bondModeAmt * 0.95f;
        float bondCurve     = clampf(bondMacro * bondModeBoost, 0.0f, 1.55f);

        float dryToReverb = 1.0f - bondMacro * (0.62f + bondModeAmt * 0.34f);
        dryToReverb = clampf(dryToReverb, 0.05f, 1.0f);

        float rvEnable = std::min(1.0f, sRvOn + sRvFz);
        float rvIn = dry * dryToReverb * rvEnable;
        rvIn += chMono * bondCurve * rvEnable * (0.95f + sOrbit * 0.06f);

        // SW2 recommendation: more obvious density / series feel
        float cleanCasc = cascHpf.Process(cascLpf.Process(prevCascOut));
        float cascFb    = fast_tanh(cleanCasc * sBondMode * 0.24f);
        rvIn += cascFb * rvEnable * (0.28f + bondMacro * 0.14f);

        rvIn = soft_limit(rvIn);

        float rvL = 0.0f, rvR = 0.0f;
        processReverb(rvIn, rvL, rvR);

        prevChOut   = chMono;
        prevRvOut   = (rvL + rvR) * 0.5f;
        prevCascOut = prevRvOut * 0.5f + prevChOut * 0.5f;

        // Per-engine tone shaping
        float chToneL = chorusToneL.Process(chL);
        float chToneR = chorusToneR.Process(chR);

        // SW4 handled safely outside the tank:
        // plate = more forward / brighter / body
        // hall  = darker / receding / softer
        float characterPlate = 1.0f - sCharacter;
        float characterHall  = sCharacter;
        float rvPreTone      = 1.0f - characterHall * 0.10f;
        float rvBodyTilt     = 1.0f + characterPlate * 0.06f - characterHall * 0.03f;

        float rvToneL = reverbToneL.Process(rvL * rvPreTone) * rvBodyTilt;
        float rvToneR = reverbToneR.Process(rvR * rvPreTone) * rvBodyTilt;

        float chLevel = sChOn * (0.98f + (1.0f - bondMacro) * 0.20f + sHalo * 0.11f + sOrbit * 0.04f);
        float rvLevel = sRvOn * (0.94f + bondMacro * 0.70f + sOrbit * 0.14f - sCharacter * 0.03f);

        if(sBondMode > 0.5f)
        {
            rvLevel += bondMacro * 0.26f;
            chLevel -= bondMacro * 0.12f;
        }
        chLevel = std::max(0.0f, chLevel);

        float wetL = chToneL * chLevel + rvToneL * rvLevel;
        float wetR = chToneR * chLevel + rvToneR * rvLevel;

        float wetBloom = 1.30f + sOrbit * 0.16f + bondMacro * 0.10f;
        if(sBondMode > 0.5f)
            wetBloom += 0.06f + bondMacro * 0.10f;
        wetL *= wetBloom;
        wetR *= wetBloom;

        float fzBoost = 1.0f + std::max(sRvFz, sChFz) * 0.25f;
        wetL *= fzBoost;
        wetR *= fzBoost;

        wetL = tape_warm(wetL);
        wetR = tape_warm(wetR);

        // Gentle output diffusion
        apL[0].g = 0.6f; apL[1].g = 0.6f; apL[2].g = 0.6f;
        apR[0].g = 0.6f; apR[1].g = 0.6f; apR[2].g = 0.6f;

        wetL = apL[0].Process(wetL);
        wetL = apL[1].Process(wetL);
        wetL = apL[2].Process(wetL);

        wetR = apR[0].Process(wetR);
        wetR = apR[1].Process(wetR);
        wetR = apR[2].Process(wetR);

        float wetMono = (wetL + wetR) * 0.84f;

        // Presence control
        float mixShaped = powf(sPresence, 0.62f);
        float mixAngle  = mixShaped * HALF_PI_F;
        float dryGain   = fast_cos_hp(mixAngle);
        float wetGain   = fast_sin_hp(mixAngle) * 1.24f;

        float processed = dry * dryGain + wetMono * wetGain;
        float output    = dry * (1.0f - anyOn) + processed * anyOn;

        output = soft_limit(output);

        out[0][i] = output;
        out[1][i] = output;
    }
}

// ============================================================
// CONTROLS
// ============================================================
static void UpdateControls()
{
    petal.ProcessAnalogControls();
    petal.ProcessDigitalControls();
    led1.Update();
    led2.Update();

    // Knobs
    tMotion   = pMotion.Process();
    tPresence = pPresence.Process();
    tBloom    = pBloom.Process();

    float rawShape = pShape.Process();
    float normShape = (rawShape - 0.2f) / (5.0f - 0.2f);
    normShape       = clamp01(normShape);
    normShape       = normShape * normShape * (3.0f - 2.0f * normShape);
    tShape          = 0.2f + normShape * (5.0f - 0.2f);

    tBond  = pBond.Process();
    tColor = pColor.Process();

    // Split tone behavior
    float colorNorm = clamp01((tColor - 300.0f) / (5000.0f - 300.0f));
    float chorusToneFreq = 650.0f + colorNorm * 3450.0f;  // 650 -> 4100
    float reverbToneFreq = 450.0f + colorNorm * 1950.0f;  // 450 -> 2400

    chorusToneL.SetFreq(chorusToneFreq, 0.95f, SR_F);
    chorusToneR.SetFreq(chorusToneFreq, 0.95f, SR_F);
    reverbToneL.SetFreq(reverbToneFreq, 0.85f, SR_F);
    reverbToneR.SetFreq(reverbToneFreq, 0.85f, SR_F);

    // Stable tank damping; SW4 no longer alters this directly
    float dampBase = 4300.0f;
    dampBase += sBond * -650.0f;
    dampBase += sOrbit * -500.0f;
    dampBase += sBondMode * -220.0f;

    float dampXmod = driftVal * (XMOD_DAMP_RANGE * 0.35f);
    float dampFreq = clampf(dampBase + dampXmod, 320.0f, 7200.0f);

    for(int t = 0; t < FDN_N; t++)
        rvDamp[t].SetFreq(dampFreq, SR_F);

    // Toggles
    tHalo      = petal.switches[Terrarium::SWITCH_1].Pressed() ? 1.0f : 0.0f;
    tBondMode  = petal.switches[Terrarium::SWITCH_2].Pressed() ? 1.0f : 0.0f;
    tOrbit     = petal.switches[Terrarium::SWITCH_3].Pressed() ? 1.0f : 0.0f;
    tCharacter = petal.switches[Terrarium::SWITCH_4].Pressed() ? 1.0f : 0.0f;

    // FS1 - Chorus
    if(fs1Lockout > 0)
    {
        fs1Lockout--;
    }
    else
    {
        bool fs1Now  = petal.switches[Terrarium::FOOTSWITCH_1].Pressed();
        bool fs1Rise = fs1Now && !fs1Prev;
        bool fs1Fall = !fs1Now && fs1Prev;

        if(fs1Rise)
        {
            fs1Timer = 0;
            fs1Held  = false;
        }

        if(fs1Now && !fs1Held)
        {
            fs1Timer++;
            if(fs1Timer >= 250)
            {
                fs1Held = true;
                if(chorusOn)
                {
                    chorusFz = !chorusFz;
                    fs1Lockout = 200;
                }
            }
        }

        if(fs1Fall && !fs1Held)
        {
            chorusOn = !chorusOn;
            if(!chorusOn)
                chorusFz = false;
            fs1Lockout = 200;
        }

        fs1Prev = fs1Now;
    }

    tChOn = chorusOn ? 1.0f : 0.0f;
    tChFz = chorusFz ? 1.0f : 0.0f;
    led1.Set(chorusOn ? (chorusFz ? 0.65f : 1.0f) : 0.0f);

    // FS2 - Reverb / Freeze
    if(fs2Lockout > 0)
    {
        fs2Lockout--;
    }
    else
    {
        bool fs2Now  = petal.switches[Terrarium::FOOTSWITCH_2].Pressed();
        bool fs2Rise = fs2Now && !fs2Prev;
        bool fs2Fall = !fs2Now && fs2Prev;

        if(fs2Rise)
        {
            fs2Timer = 0;
            fs2Held  = false;
        }

        if(fs2Now && !fs2Held)
        {
            fs2Timer++;
            if(fs2Timer >= 250)
            {
                fs2Held = true;
                reverbFz = !reverbFz;
                if(reverbFz && !reverbOn)
                    reverbOn = true;
                fs2Lockout = 200;
            }
        }

        if(fs2Fall && !fs2Held)
        {
            reverbOn = !reverbOn;
            if(!reverbOn)
                reverbFz = false;
            fs2Lockout = 200;
        }

        fs2Prev = fs2Now;
    }

    tRvOn = reverbOn ? 1.0f : 0.0f;
    tRvFz = reverbFz ? 1.0f : 0.0f;
    led2.Set(reverbOn ? (reverbFz ? 0.65f : 1.0f) : 0.0f);
}

// ============================================================
// MAIN
// ============================================================
int main()
{
    petal.Init();
    petal.SetAudioBlockSize(1);
    petal.SetAudioSampleRate(SaiHandle::Config::SampleRate::SAI_48KHZ);
    float sr = petal.AudioSampleRate();

    uint32_t fpscr = __get_FPSCR();
    fpscr |= (1 << 24);
    __set_FPSCR(fpscr);

    // Chorus init
    chDel[0].Init(chorusBufA, CHORUS_BUF_SIZE);
    chDel[1].Init(chorusBufB, CHORUS_BUF_SIZE);
    chDel[2].Init(chorusBufC, CHORUS_BUF_SIZE);

    chWriteLpf.Init(3000.0f, sr);
    chWriteHpf.Init(130.0f, sr);
    for(int v = 0; v < 3; v++)
    {
        chVoiceLpf[v].Init(2600.0f, sr);
        chVoiceDc[v].Init(0.995f);
    }

    // Reverb init
    float* rvMem[FDN_N] = {
        revBufA, revBufB, revBufC, revBufD,
        revBufE, revBufF, revBufG, revBufH
    };

    for(int t = 0; t < FDN_N; t++)
    {
        rvDel[t].Init(rvMem[t], REV_BUF_SIZE);
        rvDamp[t].Init(5400.0f, sr);

        uint32_t seed = 0xDEAD0000u + (uint32_t)(t * 0x1234567);
        tapWalk[t].Init(seed, TAP_MOD_RATES[t], sr);
    }

    rvHpfL.Init(60.0f, sr);
    rvHpfR.Init(60.0f, sr);

    float* inDiffMem[6] = {
        inDiffMemA, inDiffMemB, inDiffMemC,
        inDiffMemD, inDiffMemE, inDiffMemF
    };
    int inDiffLen[6] = {
        INDIFF_A, INDIFF_B, INDIFF_C,
        INDIFF_D, INDIFF_E, INDIFF_F
    };
    for(int s = 0; s < 6; s++)
        inDiff[s].Init(inDiffMem[s], inDiffLen[s], 0.67f);

    velvet.Init();

    // Input / shared
    inputHpf.Init(80.0f, sr);
    inputLpf.Init(7600.0f, sr);
    cascLpf.Init(900.0f, sr);
    cascHpf.Init(110.0f, sr);
    revEnergyLpf.Init(5.0f, sr);

    // Output diffusion
    apL[0].Init(apMemL1, AP_L1, 0.6f);
    apL[1].Init(apMemL2, AP_L2, 0.6f);
    apL[2].Init(apMemL3, AP_L3, 0.6f);
    apR[0].Init(apMemR1, AP_R1, 0.6f);
    apR[1].Init(apMemR2, AP_R2, 0.6f);
    apR[2].Init(apMemR3, AP_R3, 0.6f);

    // Tone
    chorusToneL.Init(1800.0f, 0.95f, sr);
    chorusToneR.Init(1800.0f, 0.95f, sr);
    reverbToneL.Init(1300.0f, 0.85f, sr);
    reverbToneR.Init(1300.0f, 0.85f, sr);

    // Params
    pMotion.Init(  petal.knob[Terrarium::KNOB_1], 0.08f, 2.8f,   Parameter::LINEAR);
    pPresence.Init(petal.knob[Terrarium::KNOB_2], 0.0f,  1.0f,   Parameter::LINEAR);
    pBloom.Init(   petal.knob[Terrarium::KNOB_3], 0.30f, 0.88f,  Parameter::LINEAR);
    pShape.Init(   petal.knob[Terrarium::KNOB_4], 0.2f,  5.0f,   Parameter::LINEAR);
    pBond.Init(    petal.knob[Terrarium::KNOB_5], 0.0f,  1.0f,   Parameter::LINEAR);
    pColor.Init(   petal.knob[Terrarium::KNOB_6], 300.0f,5000.0f,Parameter::LOGARITHMIC);

    led1.Init(petal.seed.GetPin(Terrarium::LED_1), false);
    led2.Init(petal.seed.GetPin(Terrarium::LED_2), false);

    chorusOn = false;
    reverbOn = false;
    chorusFz = false;
    reverbFz = false;

    petal.StartAdc();
    petal.StartAudio(AudioCallback);

    while(true)
    {
        UpdateControls();
        System::Delay(1);
    }
}